# Get your API key at https://www.assemblyai.com/app/account
ASSEMBLYAI_API_KEY=

# Shared password to access the app. Leave empty to disable the login
# screen (e.g. for local development).
APP_PASSWORD=

# --- Only needed for the Docker/Caddy deployment, see DEPLOY.md ---
# Domain pointing (via DNS A record) at the server's IP address.
DOMAIN=
# Basic Auth credentials guarding the app.
BASIC_AUTH_USER=
# Generate with: docker run --rm caddy:2-alpine caddy hash-password --plaintext 'yourpassword'
BASIC_AUTH_HASH=
